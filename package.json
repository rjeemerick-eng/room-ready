{
  "name": "room-ready",
  "version": "1.0.1",
  "description": "Room Ready – Classroom Availability Board",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "release": "electron-builder --mac --publish always",
    "release-win": "electron-builder --win --publish always",
    "build-win": "electron-builder --win nsis",
    "rebuild-ndi": "electron-rebuild -f -w grandiose"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.roomready.app",
    "productName": "Room Ready",
    "copyright": "Room Ready",
    "artifactName": "Room-Ready-${version}-${arch}.${ext}",
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "rjeemerick-eng",
        "repo": "room-ready"
      }
    ],
    "files": [
      "main.js",
      "server.js",
      "ndi.js",
      "updater.js",
      "public/**/*"
    ],
    "asarUnpack": [
      "node_modules/grandiose/**"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.png",
      "identity": "Robert Emerick (9BX9Z5V9U4)",
      "notarize": {
        "teamId": "9BX9Z5V9U4"
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Room Ready",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 190,
          "type": "file"
        },
        {
          "x": 390,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "shortcutName": "Room Ready",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  },
  "optionalDependencies": {
    "grandiose": "https://github.com/rse/grandiose/archive/refs/heads/master.tar.gz"
  }
}
